{
  "name": "bison-tracker",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"ui/src/**/*.{ts,svelte}\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"ui/src/**/*.{ts,svelte}\" \"vitest.config.ts\"",
    "ui": "vite dev",
    "build:ui": "vite build",
    "deploy:ui": "npm run build:ui && wrangler pages deploy ui/dist --project-name=bison-tracker-ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "hono": "^4.12.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "svelte": "^5.53.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.17",
    "@cloudflare/workers-types": "^4.20260304.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.heat": "^0.2.5",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.68.1"
  }
}
